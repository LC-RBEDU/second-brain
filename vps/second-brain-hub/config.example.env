# Coolify (cron-only) — runtime env (is_buildtime=false v UI)
VAULT_PATH=/data/mrluc
TZ=Europe/Prague
DASHBOARD_JSON=/data/mrluc/00-System/dashboard-data.json
LEGACY_TASKS=/data/mrluc/00-System/dashboard-tasks-source.json

# Kalendář — stejný SA jako RB Universe (domain-wide delegation)
GOOGLE_DRIVE_SA_JSON=
# alternativa: GOOGLE_SERVICE_ACCOUNT_JSON=
# CALENDAR_USER_EMAIL=lukas@redbuttonedu.cz
# CALENDAR_DAYS_AHEAD=2

